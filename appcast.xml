        <!--
            To publish a new release:
            1. Bump MARKETING_VERSION and CURRENT_PROJECT_VERSION in Quirky.xcodeproj (or via agvtool).
            2. Run Scripts/notarize.sh — it archives, signs with Developer ID, notarizes, staples,
               and produces build/Quirky-<version>.zip.
            3. Sign the zip with Sparkle:
               ~/Library/Developer/Xcode/DerivedData/Quirky-*/SourcePackages/artifacts/sparkle/Sparkle/bin/sign_update build/Quirky-<version>.zip
            4. Copy the edSignature and length into a new <item> below.
            5. gh release create v<version> build/Quirky-<version>.zip
            6. Commit the updated appcast.xml.
        -->
        <item>
            <title>Version 1.0 — Quirky launch</title>
            <pubDate>Sun, 25 May 2026 12:00:00 +0000</pubDate>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>Quirky 1.0</h2>
                <p>ScreenOCR is now Quirky — fully rebranded, signed with a Developer ID, and notarized by Apple.</p>
                <ul>
                    <li>New: floating mode-switcher pill — appears whenever two or more modes are enabled, parks at the nearest screen edge as an arrow tab.</li>
                    <li>SPX (pixel measurement) now coexists with OCR / HEX / DOM / SVG instead of being exclusive.</li>
                    <li>Hardened runtime + Developer ID signing + Apple notarization — install without quarantine warnings.</li>
                    <li>All previous SPX work preserved: free-drag → magnetic snap, edge & corner resize handles, hover-reveal close button, ghost-mode click-through.</li>
                </ul>
            ]]></description>
            <enclosure
                url="https://github.com/halinskiy/Quirky/releases/download/v1.0/Quirky-1.0.zip"
                type="application/octet-stream"
                sparkle:edSignature="PENDING"
                length="0"
            />
        </item>
